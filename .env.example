# .env.example – Copy to .env.development and fill in real values
# Never commit real secrets to source control!

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gigshield:gigshield_secret@localhost:5432/gigshield
# Separate dev replica for analytics read operations
DATABASE_READ_URL=postgresql+asyncpg://gigshield:gigshield_secret@localhost:5432/gigshield

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0        # General cache
REDIS_RATE_LIMIT_URL=redis://localhost:6379/1  # Rate-limiter DB

# ── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://gigshield:gigshield_secret@localhost:5672/

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace_with_256_bit_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── External APIs ────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_key
CPCB_AQI_API_KEY=your_cpcb_key
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
MSG91_AUTH_KEY=your_msg91_key
AADHAAR_API_KEY=your_aadhaar_key

# ── AWS / Storage ────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=gigshield-documents
AWS_REGION=ap-south-1

# ── Service Ports ────────────────────────────────────────────────────────────
API_GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
POLICY_SERVICE_PORT=8002
CLAIMS_SERVICE_PORT=8003
PAYOUT_SERVICE_PORT=8004
FRAUD_SERVICE_PORT=8005
RISK_ENGINE_PORT=8006
DISRUPTION_MONITOR_PORT=8007
NOTIFICATION_SERVICE_PORT=8008
ANALYTICS_SERVICE_PORT=8009

# ── App Config ───────────────────────────────────────────────────────────────
APP_ENV=development        # development | staging | production
LOG_LEVEL=DEBUG            # DEBUG | INFO | WARNING | ERROR
DEBUG=true
